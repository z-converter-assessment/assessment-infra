# {{ app_service_name }} environment
POSTGRES_HOST={{ hostvars['db-vm'].ansible_host }}
POSTGRES_PORT=5432
POSTGRES_DB={{ vault_db_name }}
POSTGRES_USER={{ vault_db_user }}
POSTGRES_PASSWORD={{ vault_db_password }}

RABBITMQ_HOST={{ hostvars['mq-vm'].ansible_host }}
RABBITMQ_PORT=5672
RABBITMQ_VHOST={{ vault_mq_vhost }}
RABBITMQ_USER={{ vault_mq_user }}
RABBITMQ_PASSWORD={{ vault_mq_password }}

REDIS_HOST={{ hostvars['cache-vm'].ansible_host }}
REDIS_PORT=6379

SECRET_KEY={{ vault_app_secret_key }}

ZDM_DEFAULT_IP={{ zdm_default_ip }}
ZDM_DEFAULT_USER={{ zdm_default_user }}
{% if ollama_api_host is defined %}
OLLAMA_HOST={{ ollama_api_host }}
OLLAMA_PORT={{ ollama_port }}
OLLAMA_MODEL={{ ollama_model }}
{% endif %}
