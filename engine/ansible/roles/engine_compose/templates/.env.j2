APP_ENV={{ engine_app_env }}
LOG_FORMAT={{ engine_log_format }}

# ── 이미지 핀 ─────────────────────────────────────────────────────
# base compose 기본값도 release CI가 태그 semver로 self-pin하지만, engine_version과
# 명시 결선해 동적 버전 선택(dispatch payload)이 이미지 tag까지 확실히 전파되게 함.
ENGINE_IMAGE=ghcr.io/z-converter-assessment/assessment-engine:{{ engine_version }}

# ── Postgres — compose 서비스명으로 접속 ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ vault_db_name }}
POSTGRES_USER={{ vault_db_user }}
POSTGRES_PASSWORD={{ vault_db_password }}
SQLALCHEMY_ECHO=false

# ── pgAdmin (v0.5.0 base compose 신규 서비스) ─────────────────────
PGADMIN_EMAIL={{ engine_pgadmin_email }}
PGADMIN_PASSWORD={{ vault_pgadmin_password }}
PGADMIN_PORT={{ engine_pgadmin_port }}

# ── RabbitMQ — compose 서비스명으로 접속 ──────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_VHOST={{ vault_mq_vhost }}
RABBITMQ_USER={{ vault_mq_user }}
RABBITMQ_PASSWORD={{ vault_mq_password }}
RABBITMQ_EXCHANGE={{ engine_mq_exchange }}
RABBITMQ_ROUTING_KEY_INVENTORY={{ engine_mq_routing_key_inventory }}
RABBITMQ_ROUTING_KEY_METRICS={{ engine_mq_routing_key_metrics }}
RABBITMQ_ROUTING_KEY_ERROR={{ engine_mq_routing_key_error }}

# task 라우팅 — 엔진 pydantic 필드명(RABBITMQ_TASK_*) 그대로여야 인식.
# 값은 agent 측(WORKER_TASK_* prefix)과 동일해야 하나 키 prefix는 다름.
RABBITMQ_TASK_EXCHANGE={{ engine_mq_task_exchange }}
RABBITMQ_TASK_QUEUE_PREFIX={{ engine_mq_task_queue_prefix }}
RABBITMQ_TASK_INSTALL_KEY_PREFIX={{ engine_mq_task_install_key_prefix }}
RABBITMQ_ROUTING_KEY_TASK_RESULT={{ engine_mq_task_result_key }}
RABBITMQ_QUEUE_WORKER_RESULT={{ engine_mq_worker_result_queue }}

RABBITMQ_ROUTING_KEY_DIAGNOSTIC={{ engine_diagnostic_routing_key }}
RABBITMQ_DIAGNOSTIC_QUEUE_TTL_MS={{ engine_diagnostic_queue_ttl_ms }}
RABBITMQ_DIAGNOSTIC_QUEUE_MAX_LEN={{ engine_diagnostic_queue_max_len }}

# ── Redis — compose 서비스명으로 접속 ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY={{ vault_app_secret_key }}

# ── web 전용 ──────────────────────────────────────────────────────
WEB_PORT=8000
INSTALL_TIMEOUT_SEC={{ engine_install_timeout_sec }}

ZDM_DEFAULT_IP={{ zdm_default_ip }}
ZDM_DEFAULT_USER={{ zdm_default_user }}
ZDM_PACKAGE_PATH={{ zdm_package_path }}
ZDM_PACKAGE_SCRIPT={{ zdm_package_script }}
ZDM_META_CONNECT_TIMEOUT_SEC={{ zdm_meta_connect_timeout_sec }}
ZDM_META_TOTAL_TIMEOUT_SEC={{ zdm_meta_total_timeout_sec }}
REDIS_TTL_ZDM_PACKAGE_SHA256={{ redis_ttl_zdm_package_sha256 }}

# ── diagnostic-worker → Ollama 좌표 (engine-vm 동거, AI VM 원격 접속) ──
# base compose default(http://ollama:11434·qwen2.5:1.5b)는 base에 ollama 서비스가
# 없어 미주입 시 narrative pending으로 degrade. AI VM Ollama·실서빙 모델로 명시 주입.
OLLAMA_BASE_URL={{ ollama_base_url }}
OLLAMA_MODEL={{ ollama_model }}

# ── 볼륨 마운트 경로 (compose bind mount source) ──────────────────
# 키명 PGDATA_HOST/MQ_DATA_HOST 정확히 일치해야 base가 인식 → host 절대경로 bind.
# 다른 이름이면 base가 default(named volume)로 떨어져 Cinder bind 실패.
PGDATA_HOST={{ db_mount_path }}/pgdata
MQ_DATA_HOST={{ mq_mount_path }}
