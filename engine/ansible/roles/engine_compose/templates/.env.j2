APP_ENV={{ engine_app_env }}
LOG_FORMAT={{ engine_log_format }}

# ── Postgres — compose 서비스명으로 접속 ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ vault_db_name }}
POSTGRES_USER={{ vault_db_user }}
POSTGRES_PASSWORD={{ vault_db_password }}

# ── RabbitMQ — compose 서비스명으로 접속 ──────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST={{ vault_mq_vhost }}
RABBITMQ_USER={{ vault_mq_user }}
RABBITMQ_PASSWORD={{ vault_mq_password }}
RABBITMQ_EXCHANGE={{ engine_mq_exchange }}
RABBITMQ_ROUTING_KEY_INVENTORY={{ engine_mq_routing_key_inventory }}
RABBITMQ_ROUTING_KEY_METRICS={{ engine_mq_routing_key_metrics }}
RABBITMQ_ROUTING_KEY_ERROR={{ engine_mq_routing_key_error }}

WORKER_TASK_EXCHANGE={{ engine_mq_task_exchange }}
WORKER_TASK_RESULT_KEY={{ engine_mq_task_result_key }}

DIAGNOSTIC_ROUTING_KEY={{ engine_diagnostic_routing_key }}
DIAGNOSTIC_QUEUE_TTL_MS={{ engine_diagnostic_queue_ttl_ms }}
DIAGNOSTIC_QUEUE_MAX_LEN={{ engine_diagnostic_queue_max_len }}

# ── Redis — compose 서비스명으로 접속 ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY={{ vault_app_secret_key }}

ZDM_DEFAULT_IP={{ zdm_default_ip }}
ZDM_DEFAULT_USER={{ zdm_default_user }}
ZDM_PACKAGE_PATH={{ zdm_package_path }}
ZDM_PACKAGE_SCRIPT={{ zdm_package_script }}
ZDM_META_CONNECT_TIMEOUT_SEC={{ zdm_meta_connect_timeout_sec }}
ZDM_META_TOTAL_TIMEOUT_SEC={{ zdm_meta_total_timeout_sec }}
REDIS_TTL_ZDM_PACKAGE_SHA256={{ redis_ttl_zdm_package_sha256 }}

# ── 볼륨 마운트 경로 (compose bind mount source) ──────────────────
PGDATA={{ db_mount_path }}/pgdata
MQ_DATA={{ mq_mount_path }}
