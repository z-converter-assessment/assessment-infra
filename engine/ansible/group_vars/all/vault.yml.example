# Engine secret 카탈로그 — 모든 vault 변수의 단일 정의 지점.
#
# 사용:
#   1. cp vault.yml.example vault.yml
#   2. 모든 CHANGEME를 실제 값으로 치환 (prod 정책: weak default 거부)
#   3. ansible-vault encrypt vault.yml
#   4. ~/.vault-pass (mode 0400)에 복호화 패스워드 저장
#
# 사용처: app role (api·consumer) env 주입, postgres role 계정 생성, rabbitmq role 계정 생성,
#         agent role (agent/ansible/group_vars/all/vault.yml 은 본 파일의 symlink).
# 환경변수 키 카탈로그: docs/operations/env-engine.md

# ── PostgreSQL ─────────────────────────────────────────────────────
# postgres role이 본 값으로 DB·user를 create.
# app role이 본 값을 POSTGRES_DB·POSTGRES_USER·POSTGRES_PASSWORD로 주입.
vault_db_name: assessment
vault_db_user: assessment
vault_db_password: CHANGEME

# ── RabbitMQ ───────────────────────────────────────────────────────
# rabbitmq role이 본 값으로 vhost·user 생성.
# app role이 본 값을 RABBITMQ_VHOST·RABBITMQ_USER·RABBITMQ_PASSWORD로 주입.
# agent도 같은 broker에 같은 자격으로 접속 — agent vault.yml은 본 파일의 symlink.
vault_mq_vhost: assessment
vault_mq_user: assessment
vault_mq_password: CHANGEME

# ── Application ────────────────────────────────────────────────────
# api·consumer가 본 값을 SECRET_KEY로 주입 (session/JWT 서명).
# prod 권장: openssl rand -base64 32
vault_app_secret_key: CHANGEME
