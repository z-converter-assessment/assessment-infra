# Agent secret 카탈로그.
#
# 사용:
#   1. cp vault.yml.example vault.yml
#   2. 모든 CHANGEME를 실제 값으로 치환
#   3. ansible-vault encrypt vault.yml
#   4. ~/.vault-pass (mode 0400)에 복호화 패스워드 저장
#
# 사용처: agent role의 agent.env.j2 — agent가 engine MQ에 AMQP 접속.
# 환경변수 키 카탈로그: docs/operations/env-agent.md
#
# *** 본 값은 engine/ansible/group_vars/all/vault.yml과 반드시 동일 *** —
# agent가 engine 측 RabbitMQ에 접속하므로 동일 vhost·user·password 사용.

# ── RabbitMQ (engine과 공유) ──────────────────────────────────────
vault_mq_vhost: assessment
vault_mq_user: assessment
vault_mq_password: CHANGEME
