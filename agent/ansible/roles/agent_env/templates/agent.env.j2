RABBITMQ_HOST={{ engine_mq_host }}
RABBITMQ_PORT={{ engine_mq_port | default(5672) }}
RABBITMQ_TLS_ENABLED={{ rabbitmq_tls_enabled | string | lower }}
RABBITMQ_VHOST={{ vault_mq_vhost | default('assessment') }}
RABBITMQ_EXCHANGE={{ mq_exchange }}
RABBITMQ_ROUTING_KEY_INVENTORY={{ mq_routing_key_inventory }}
RABBITMQ_ROUTING_KEY_METRICS={{ mq_routing_key_metrics }}
RABBITMQ_ROUTING_KEY_ERROR={{ mq_routing_key_error }}

# Worker (CM2 — task.install consume / task.result publish)
WORKER_TASK_EXCHANGE={{ mq_task_exchange }}
WORKER_TASK_QUEUE_PREFIX={{ mq_task_queue_prefix }}
WORKER_TASK_RESULT_KEY={{ mq_task_result_key }}
WORKER_DOWNLOAD_ALLOWED_HOSTS={{ worker_download_allowed_hosts }}

# Agent 루프/drain (drain 합은 systemd TimeoutStopSec와 정합)
AGENT_INTERVAL_SEC={{ agent_interval_sec }}
AGENT_INVENTORY_REFRESH_SEC={{ agent_inventory_refresh_sec }}
AGENT_DRAIN_GRACE_SEC={{ agent_drain_grace_sec }}
AGENT_DRAIN_TERM_SEC={{ agent_drain_term_sec }}
AGENT_DRAIN_PUBLISH_SEC={{ agent_drain_publish_sec }}
