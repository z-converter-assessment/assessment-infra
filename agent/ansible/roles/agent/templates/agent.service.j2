[Unit]
Description=assessment-agent
After=network.target

[Service]
Type=simple
User={{ agent_user }}
Group={{ agent_group }}
WorkingDirectory={{ agent_dir }}
EnvironmentFile={{ agent_dir }}/{{ agent_service_name }}.env
ExecStart={{ agent_binary_dest }}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
