# {{ app_service_name }} environment
# 실제 키 이름은 assessment-engine docs/operations/env.md 참조 후 수정
DATABASE_URL=postgresql://{{ vault_db_user }}:{{ vault_db_password }}@{{ hostvars['db-vm'].ansible_host }}/{{ vault_db_name }}
BROKER_URL=amqp://{{ vault_mq_user }}:{{ vault_mq_password }}@{{ hostvars['mq-vm'].ansible_host }}/{{ vault_mq_vhost }}
SECRET_KEY={{ vault_app_secret_key }}
